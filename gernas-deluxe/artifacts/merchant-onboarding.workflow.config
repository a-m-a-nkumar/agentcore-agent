{
  "version": "1.0",
  "schema": "dlx-agentic-os/workflow-import",
  "workflow": {
    "name": "SMB Merchant Onboarding Pipeline",
    "description": "Full end-to-end merchant onboarding — KYB verification, document collection, risk scoring, approval routing and terminal provisioning.",
    "segment": "Merchant Services",
    "trigger": "webhook/new-merchant-application",
    "output": "Merchant Onboarded — Live in Dashboard",
    "tags": ["onboarding", "kyb", "merchant", "risk"]
  },
  "agents": [
    {
      "step": 1,
      "agent_name": "KYB Verification Agent",
      "description": "Verifies business identity against government and commercial databases including D&B and Middesk.",
      "tools": ["kyb-verify", "sanctions-check", "dnb-lookup"],
      "status": "full",
      "covers": "Business identity verification, sanctions screening, beneficial ownership check",
      "sla_minutes": 2
    },
    {
      "step": 2,
      "agent_name": "Document Collection Bot",
      "description": "Requests, parses and validates required merchant documents using OCR and rule-based validation.",
      "tools": ["doc-parser", "email-send", "ocr-extract"],
      "status": "full",
      "covers": "EIN verification, bank account collection, business license validation",
      "sla_minutes": 10
    },
    {
      "step": 3,
      "agent_name": "Risk Scoring Engine",
      "description": "Scores merchant risk profile across 12 signals including credit history, fraud signals and industry risk.",
      "tools": ["risk-model", "crm-write", "fraud-signals"],
      "status": "full",
      "covers": "Credit scoring, fraud history check, industry and geography risk assessment",
      "sla_minutes": 1
    },
    {
      "step": 4,
      "agent_name": "Approval Notifier",
      "description": "Routes approval decision to the right approver and notifies all stakeholders of the outcome.",
      "tools": ["workflow-api", "notify-send", "crm-update"],
      "status": "full",
      "covers": "Decision routing, stakeholder notifications, CRM status update",
      "sla_minutes": 5
    }
  ],
  "metadata": {
    "created_by": "DLX_AGENTIC_OS",
    "team": "Merchant Ops",
    "expected_sla": "24 hours end-to-end",
    "avg_success_rate": 96.2,
    "tasks_per_day": 47
  }
}
